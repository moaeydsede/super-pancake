rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentData() {
      return currentUser().data;
    }

    function isAdmin() {
      return signedIn() && (request.auth.uid == 'JxKXouwjdadht4wSMPf1qtbeW9n1' || (currentUser().exists() && currentData().role == 'admin'));
    }

    function isActive() {
      return signedIn() && currentUser().exists() && currentData().status == 'active';
    }

    function hasPermission(key) {
      return isAdmin() || (isActive() && currentData().permissions[key] == true);
    }

    function samePrivileges() {
      return request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.permissions == resource.data.permissions
        && request.resource.data.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if isAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && request.auth.uid == 'JxKXouwjdadht4wSMPf1qtbeW9n1'
          && request.resource.data.role == 'admin'
          && request.resource.data.status == 'active');
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId && samePrivileges());
      allow delete: if false;
    }

    match /materials/{docId} {
      allow read: if isActive();
      allow create, update, delete: if hasPermission('materials');
    }

    match /openingInvoices/{docId} {
      allow read: if isActive();
      allow create, update, delete: if hasPermission('openingBalance');
    }

    match /inboundInvoices/{docId} {
      allow read: if isActive();
      allow create, update, delete: if hasPermission('inbound');
    }

    match /issueInvoices/{docId} {
      allow read: if isActive();
      allow create, update, delete: if hasPermission('issue');
    }

    match /auditLogs/{docId} {
      allow read: if hasPermission('auditLogs');
      allow create: if isActive();
      allow update, delete: if isAdmin();
    }
  }
}
